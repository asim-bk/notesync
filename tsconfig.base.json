{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@notesync/shared-types": [
        "packages/shared-types/src"
      ],
      "@notesync/note-domain": [
        "packages/note-domain/src"
      ],
      "@notesync/crypto-core": [
        "packages/crypto-core/src"
      ]
    }
  }
}
