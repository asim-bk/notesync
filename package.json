{
  "name": "notesync",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm --workspace @notesync/api run dev",
    "dev:mobile": "npm --workspace @notesync/mobile run start",
    "build": "npm run build --workspaces"
  }
}
